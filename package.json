{
  "name": "looper",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "turbo run dev",
    "dev:be": "pnpm --filter backend dev",
    "dev:fe": "pnpm --filter frontend dev",
    "build": "turbo run build --filter=!e2e",
    "test": "turbo run test --filter=!e2e",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "pnpm --filter e2e test",
    "generate": "turbo run generate",
    "typecheck": "turbo run type-check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "barrels": "barrelsby --config .barrelsby.json && pnpm format",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,md,yml,yaml,graphql}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,mjs,json,md,yml,yaml,graphql}\"",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:logs": "docker compose logs -f backend frontend",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "barrelsby": "^2.8.1",
    "knip": "^5.88.1",
    "lefthook": "^2.1.6",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.63.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.9",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.9.3"
    },
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "cpu-features",
      "esbuild",
      "lefthook",
      "prisma",
      "protobufjs",
      "ssh2"
    ]
  }
}
