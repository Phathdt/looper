{
  "extends": "@looper/tsconfig/nest.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@modules/*": ["src/modules/*"],
      "@common/*": ["src/common/*"]
    },
    "sourceMap": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "strictBindCallApply": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
