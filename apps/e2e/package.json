{
  "name": "e2e",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "test": "mkdir -p test-results && cucumber-js --config .cucumber.js",
    "test:headed": "HEADLESS=false cucumber-js --config .cucumber.js",
    "test:smoke": "cucumber-js --config .cucumber.js --tags @smoke",
    "test:auth": "cucumber-js --config .cucumber.js --tags @auth",
    "test:feed": "cucumber-js --config .cucumber.js --tags @feed",
    "type-check": "tsc --noEmit",
    "install:browsers": "playwright install chromium",
    "clean": "rm -rf test-results"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@looper/tsconfig": "workspace:*",
    "@cucumber/cucumber": "^12.8.2",
    "@playwright/test": "^1.59.1",
    "tsconfig-paths": "^4.2.0"
  }
}
