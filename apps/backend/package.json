{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "SWCRC=true node --import @swc-node/register/esm-register --watch src/main.ts",
    "build": "rolldown -c",
    "start": "node dist/main.cjs",
    "test": "vitest run --config vitest.config.ts && vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "node --import @swc-node/register/esm-register prisma/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.3.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/graphql": "^13.3.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.19",
    "@oxc-project/runtime": "^0.100.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dataloader": "^2.2.3",
    "dotenv": "^17.4.2",
    "graphql": "^16.13.2",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.3.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@looper/tsconfig": "workspace:*",
    "@nestjs/testing": "^11.1.19",
    "@swc-node/register": "^1.10.0",
    "@swc/core": "^1.15.30",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "rolldown": "^1.0.0-rc.17",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  }
}
