{
  "name": "looper",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev",
    "dev:be": "pnpm --filter backend dev",
    "dev:fe": "pnpm --filter frontend dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "generate": "turbo run generate",
    "typecheck": "turbo run type-check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,md,yml,yaml,graphql}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,mjs,json,md,yml,yaml,graphql}\"",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^1.8.0",
    "lint-staged": "^15.2.10",
    "oxlint": "^0.13.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
