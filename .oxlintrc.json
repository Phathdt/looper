{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "typescript/no-extraneous-class": "off",
    "import/no-unassigned-import": "off",
    "no-underscore-dangle": ["warn", { "allow": ["_count", "__typename", "__meta__", "__apiType"] }]
  },
  "ignorePatterns": ["**/dist/**", "**/.turbo/**", "**/node_modules/**", "**/generated/**"]
}
