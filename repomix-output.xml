// jsdom lacks IntersectionObserver — stub it for components that observe sentinels
if (!('IntersectionObserver' in globalThis)) {
  class NoopIntersectionObserver {
    observe = vi.fn()
    disconnect = vi.fn()
    unobserve = vi.fn()
    takeRecords = vi.fn(() => [])
    root = null
    rootMargin = ''
    thresholds = []
